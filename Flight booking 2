class Flight:
    def __init__(self, flight_no, destination, price):
        self.flight_no = flight_no
        self.destination = destination
        self.price = price

    def show_flight(self):
        print("Flight No:", self.flight_no)
        print("Destination:", self.destination)
        print("Price:", self.price)


class Passenger:
    def __init__(self, name):
        self.name = name

    def book_ticket(self, flight):
        print("\nTicket Booked Successfully!")
        print("Passenger:", self.name)
        flight.show_flight()


# User input
flight_no = input("Enter Flight Number: ")
destination = input("Enter Destination: ")
price = int(input("Enter Ticket Price: "))

name = input("Enter Passenger Name: ")

# Objects
flight1 = Flight(flight_no, destination, price)
passenger1 = Passenger(name)

# Booking
passenger1.book_ticket(flight1)
